# =============================================================================
# Stellantis-Dictionary — Exemplo de variáveis de ambiente.
#
# COPIE este arquivo para `.env` (que NÃO é commitado) e preencha os valores.
#   cp .env.example .env
#
# REGRAS (skill devops-baseline / SPEC 02 §3.6):
#   - NUNCA commite `.env` nem segredos reais. Este arquivo só tem placeholders.
#   - Valores marcados __CHANGE_ME__ devem ser gerados por ambiente e nunca
#     reutilizados entre ambientes (dev/piloto/prod).
#   - Gere segredos fortes, ex.:  openssl rand -hex 32
#   - Segredos reais de deploy passam por secret manager do alvo (D6) e pela
#     revisão do Segurança Lead.
# =============================================================================

# --- App --------------------------------------------------------------------
NODE_ENV=development            # development | test | production
APP_PORT=3000                   # porta HTTP do backend (mapeada no compose)
LOG_LEVEL=info                  # debug (só dev) | info | warn | error

# --- Banco de dados (Postgres + pgvector) -----------------------------------
POSTGRES_USER=stellantis                    # usuário do banco
POSTGRES_PASSWORD=__CHANGE_ME__             # SENHA — gerar; nunca commitar
POSTGRES_DB=stellantis_dict                 # nome do banco
POSTGRES_PORT=5432                          # porta publicada no host (só DEV)
# String de conexão usada pela app. Host `db` = nome do serviço no compose.
DATABASE_URL=postgres://stellantis:__CHANGE_ME__@db:5432/stellantis_dict

# --- Autenticação / JWT (SPEC 02 §3.1) --------------------------------------
JWT_SECRET=__CHANGE_ME__                    # assina access tokens — gerar
JWT_REFRESH_SECRET=__CHANGE_ME__            # assina refresh tokens — gerar (distinto)
JWT_ACCESS_TTL=15m                          # validade do access token
JWT_REFRESH_TTL=7d                          # validade do refresh token

# --- Provedor de LLM (adapter multi-provedor — SPEC 02 §2 / decisão D5 aberta)
# D5 (qual provedor) segue EM ABERTO no PDR. A app trata isto como configurável
# via port/adapter: trocar de provedor não muda o código, só estas variáveis.
LLM_PROVIDER=claude                         # claude | openai (selecionado por env)
LLM_API_KEY=__CHANGE_ME__                   # chave do provedor ativo — nunca commitar
LLM_MODEL=                                  # opcional: modelo específico (ex.: claude-... / gpt-...)
# LLM_API_BASE_URL=                         # opcional: override de endpoint (proxy corporativo)

# --- Hospedagem (decisão D6 — TBD no PDR) -----------------------------------
# Não altera o código; só orienta a infra. Diferenças reais entre alvos ficam
# em compose override / IaC, não aqui.
DEPLOY_TARGET=local                         # local | vps | cloud
# APP_PUBLIC_URL=https://...                # URL pública (obrigatoriamente HTTPS em deploy real)
